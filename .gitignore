# -----------------------
# Android / Gradle
# -----------------------

# Gradle build files
**/build/
.gradle/
build/

# Gradle wrapper (keep wrapper jar checked in)
!gradle/wrapper/gradle-wrapper.jar

# Local configuration file (SDK path, etc.)
local.properties

# Proguard / R8 generated mapping or caches
/proguard/
/mapping.txt

# Android Studio / IntelliJ
.idea/
*.iws
*.iml
*.ipr

# User-specific files
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/dictionaries/
.idea/vcs.xml
.idea/modules.xml
.idea/.name

# OS files
.DS_Store
Thumbs.db

# -----------------------
# Application packaging
# -----------------------
*.apk
*.ap_
*.aab
*.xapk

# -----------------------
# Compiled / generated
# -----------------------
*.class
*.dex
*.so
*.o
*.obj

# Java / Kotlin specific
*.jar
*.war
*.ear

# -----------------------
# Native / NDK
# -----------------------
/obj/
/out/
/.externalNativeBuild/
/.cxx/
/*.ndkBuild

# CMake build output
cmake-build-*/

# -----------------------
# IDE / Editor
# -----------------------
.vscode/
*.swp
*~.nib
*.sublime-workspace
*.sublime-project

# -----------------------
# Test / coverage / reports
# -----------------------
/coverage/
/reports/
/test-results/

# -----------------------
# Logs and misc
# -----------------------
*.log
*.tmp
*.temp
*.orig
*.rej

# -----------------------
# Signing & credentials
# -----------------------
# Do NOT commit keystore files or signing properties with secrets.
# If you must, remove these lines; otherwise keep them ignored.
*.jks
*.keystore
keystore.properties
signing.properties

# -----------------------
# Firebase / Google services / Crashlytics
# -----------------------
# google-services.json often contains project-specific settings and keys.
# Keep ignored if you store secrets locally; remove if you intentionally commit it.
google-services.json
firebase-debug.log
fabric.properties

# -----------------------
# Android Studio captures and profiling
# -----------------------
captures/
*.hprof

# -----------------------
# Misc Android files
# -----------------------
# Generated by Android build tools
android/gradle-wrapper.jar
output.json

# Keep any local env files out of repo
.env